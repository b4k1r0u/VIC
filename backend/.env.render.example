APP_NAME=RASED API
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
SECRET_KEY=<generate-on-render>

DATABASE_URL=<render-external-database-url-with-postgresql+asyncpg-scheme>
ALEMBIC_DATABASE_URL=<render-external-database-url-with-postgresql-scheme>

REDIS_URL=<optional-render-redis-url>
GEMINI_API_KEY=<your-gemini-key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-1.5-flash

USGS_POLL_INTERVAL=60
MIN_ALERT_MAGNITUDE=4.0
AUTO_SIMULATE_THRESHOLD=5.0

REINSURANCE_CESSION_RATE=0.70
RETENTION_RATE=0.30

CATBOOST_MODEL_PATH=ml_models/catboost_model.cbm
DAMAGE_CNN_PATH=ml_models/damage_cnn.pt

UPLOADS_DIR=uploads
HEATMAPS_DIR=uploads/heatmaps

CORS_ORIGINS=https://your-frontend-domain.vercel.app
