# ── RASED Frontend Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Backend REST API base URL (no trailing slash)
VITE_API_URL=https://s-ismicrisk.onrender.com

# Backend WebSocket base URL (ws:// or wss://)
VITE_WS_URL=wss://s-ismicrisk.onrender.com
